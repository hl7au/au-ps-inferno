# frozen_string_literal: true

<% groups.each do |group| -%>
require_relative '<%= group[:require_path] %>'

<% end -%>
module AUPSTestKit
  # Automatically generated top-level test suite for the AU PS <%= suite_version %> implementation guide.
  class <%= class_name %> < Inferno::TestSuite
    id :<%= suite_id %>
    title 'AU PS <%= suite_version %> Test Suite'
    description 'Validates AU PS (Australian Primary Care and Shared Health) bundles, ' \
                'compositions, sections, and server CapabilityStatement support for the ' \
                '<%= suite_version %> implementation guide.'

    fhir_resource_validator do
      igs 'hl7.fhir.au.ps#<%= suite_version %>'

      cli_context do
        txServer ENV.fetch('TX_SERVER_URL', 'https://tx.dev.hl7.org.au/fhir')
        noEcosystem true
      end
    end

<% groups.each do |group| -%>
    group from: :<%= group[:group_id] %>

<% end -%>
  end
end
