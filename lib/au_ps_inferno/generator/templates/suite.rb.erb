# frozen_string_literal: true

<% groups.each do |group| %>
require_relative './<%= group[:file_path].split('.rb').first %>'
<% end %>

module AUPSTestKit
  # The test suite for the AU PS Inferno profile.
  class Suite<%= version_suffix %> < Inferno::TestSuite
    id :au_ps_suite_<%= version_suffix %>
    title 'AU PS Inferno <%= suite_version %>'
    description 'This suite includes $summary operation tests.'

    fhir_resource_validator do
      igs 'hl7.fhir.au.ps#<%= suite_version %>'

      cli_context do
        txServer ENV.fetch('TX_SERVER_URL') { 'https://tx.dev.hl7.org.au/fhir' }
      end
    end

    <% groups.each do |group| %>
    group from: :<%= group[:attributes][:group_id] %>
    <% end %>
  end
end
