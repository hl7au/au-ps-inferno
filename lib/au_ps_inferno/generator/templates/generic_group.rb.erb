# frozen_string_literal: true

<% tests.each do |test| %>
require_relative '<%= test[:file_path].split('.rb').first.split('/').last %>'
<% end %>

module AUPSTestKit
  # Automatically generated test group for <%= group_title %>
  class <%= group_class_name %> < Inferno::TestGroup
    title '<%= group_title %>'
    description '<%= group_description %>'
    id :<%= group_id %>

    <% tests.each do |test| %>
    test from: :<%= test[:attributes][:test_id] %>
    <% end %>
  end
end
