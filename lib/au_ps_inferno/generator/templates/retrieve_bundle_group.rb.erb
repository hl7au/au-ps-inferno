# frozen_string_literal: true

<% tests.each do |test| %>
require_relative './<%= test[:file_name].sub(/\.rb$/, '') %>'
<% end %>

module AUPSTestKit
  # <%= group_class_comment %>
  class <%= group_class_name %> < Inferno::TestGroup
    title '<%= group_title %>'
    description '<%= group_description %>'
    id :<%= group_id %>

    run_as_group

    <% tests.each do |test| %>
    test from: :<%= test[:test_id] %>
    <% end %>
  end
end
