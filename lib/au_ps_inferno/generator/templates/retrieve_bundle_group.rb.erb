# frozen_string_literal: true

require_relative '../../utils/constants'
<% tests.each do |test| %>
require_relative './<%= test[:file_name].sub(/\.rb$/, '') %>'
<% end %>

module AUPSTestKit
  # Retrieve document Bundle using Bundle read interaction or other HTTP GET request and verify
  # is valid AU PS Bundle
  class <%= group_class_name %> < Inferno::TestGroup
    extend Constants

    title '<%= group_title %>'
    description '<%= group_description %>'
    id :<%= group_id %>

    run_as_group

    <% tests.each do |test| %>
    test from: :<%= test[:test_id] %>
    <% end %>
  end
end
