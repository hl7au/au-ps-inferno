# frozen_string_literal: true

<% groups.each do |group| %>
require_relative '<%= group[:path] %>'
<% end %>

module AUPSTestKit
  # Automatically generated high order group for <%= title %>
  class <%= class_name %> < Inferno::TestGroup
    title '<%= title %>'
    description '<%= description %>'
    id :<%= id %>
    <% if optional %>
    optional
    <% end %>
    <% if run_as_group %>
    run_as_group
    <% end %>

    <% groups.each do |group| %>
    group from: :<%= group[:id] %>
    <% end %>
  end
end
