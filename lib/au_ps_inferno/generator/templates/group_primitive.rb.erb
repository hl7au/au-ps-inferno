# frozen_string_literal: true

<% imports.each do |import| %>
require_relative '<%= import %>'
<% end %>
<% tests.each do |test| %>
require_relative '<%= test[:path] %>'
<% end %>

module AUPSTestKit
  # Automatically generated primitive group for <%= title %>
  class <%= class_name %> < Inferno::TestGroup
    title '<%= title %>'
    description '<%= description %>'
    id :<%= id %>
    <% if optional %>
    optional
    <% end %>
    <% if run_as_group %>
    run_as_group
    <% end %>

    <% tests.each do |test| %>
    test from: :<%= test[:id] %>
    <% end %>
  end
end
